        <mxCell id="fBMGaBAVBTN2UTNKNQf1-915" value="Просмотреть/ответить в диалог с пользователем" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=13;strokeColor=#FF0000;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="2333" y="3897" width="243" height="30" as="geometry" />
